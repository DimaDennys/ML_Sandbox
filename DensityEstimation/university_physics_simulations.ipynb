   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 🔭 University Physics: Simulations & Numerical Methods\n",
    "**Topics Covered:** Projectile Motion | Simple Harmonic Motion | Wave Interference | Planetary Orbits | Heat Diffusion\n",
    "\n",
    "---"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.animation\n",
    "from scipy.integrate import solve_ivp\n",
    "from scipy.linalg import solve\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "np.random.seed(0)\n",
    "\n",
    "plt.rcParams.update({\n",
    "    'figure.facecolor': '#0f1117', 'axes.facecolor': '#1a1d27',\n",
    "    'axes.edgecolor': '#444', 'axes.labelcolor': '#cdd6f4',\n",
    "    'xtick.color': '#cdd6f4', 'ytick.color': '#cdd6f4',\n",
    "    'text.color': '#cdd6f4', 'grid.color': '#2a2d3e',\n",
    "    'grid.linestyle': '--', 'font.family': 'monospace',\n",
    "})\n",
    "COLORS = ['#89b4fa', '#a6e3a1', '#fab387', '#f38ba8', '#cba6f7', '#94e2d5']\n",
    "print('✅ Libraries loaded.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 1 · Projectile Motion — With and Without Air Resistance\n",
    "\n",
    "**No drag:** $\\ddot{x}=0,\\ \\ddot{y}=-g$ &nbsp;&nbsp; **With drag:** $\\ddot{\\mathbf{r}} = -g\\hat{j} - \\dfrac{k}{m}v\\,\\dot{\\mathbf{r}}$"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "g  = 9.81\n",
    "v0 = 50.0     # m/s\n",
    "m  = 0.5      # kg\n",
    "k  = 0.05     # drag coefficient  [N·s/m]\n",
    "angles = [15, 30, 45, 60, 75]\n",
    "\n",
    "def projectile_drag(t, y):\n",
    "    x, vx, yp, vy = y\n",
    "    v = np.sqrt(vx**2 + vy**2)\n",
    "    ax = -(k/m) * v * vx\n",
    "    ay = -g - (k/m) * v * vy\n",
    "    return [vx, ax, vy, ay]\n",
    "\n",
    "def hit_ground(t, y): return y[2]  # y-position = 0\n",
    "hit_ground.terminal  = True\n",
    "hit_ground.direction = -1\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 6))\n",
    "fig.suptitle('Projectile Motion — Effect of Air Resistance', fontsize=13, fontweight='bold', color='#89b4fa')\n",
    "\n",
    "for i, angle in enumerate(angles):\n",
    "    th = np.radians(angle)\n",
    "    vx0, vy0 = v0*np.cos(th), v0*np.sin(th)\n",
    "\n",
    "    # No drag (analytical)\n",
    "    T_flight = 2 * vy0 / g\n",
    "    t_nd = np.linspace(0, T_flight, 300)\n",
    "    x_nd = vx0 * t_nd\n",
    "    y_nd = vy0 * t_nd - 0.5 * g * t_nd**2\n",
    "\n",
    "    # With drag (numerical)\n",
    "    sol = solve_ivp(projectile_drag, [0, 30], [0, vx0, 0, vy0],\n",
    "                    events=hit_ground, max_step=0.01, rtol=1e-8)\n",
    "    x_d, y_d = sol.y[0], sol.y[2]\n",
    "\n",
    "    axes[0].plot(x_nd, y_nd, color=COLORS[i % len(COLORS)], lw=2,  label=f'{angle}°')\n",
    "    axes[1].plot(x_d,  y_d,  color=COLORS[i % len(COLORS)], lw=2,  label=f'{angle}°')\n",
    "\n",
    "for ax, title in zip(axes, ['No Air Resistance (Analytical)', 'With Air Resistance (Numerical)']):\n",
    "    ax.set(xlabel='x (m)', ylabel='y (m)', title=title)\n",
    "    ax.set_ylim(bottom=0)\n",
    "    ax.legend(title='Launch angle', fontsize=9)\n",
    "    ax.grid(True)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('projectile.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 2 · Simple Harmonic Motion & Damped Oscillator\n",
    "\n",
    "$$m\\ddot{x} + c\\dot{x} + kx = F_0\\cos(\\omega t)$$"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def oscillator(t, y, m, c, k, F0, omega_drive):\n",
    "    x, v = y\n",
    "    F_drive = F0 * np.cos(omega_drive * t)\n",
    "    ax = (-c*v - k*x + F_drive) / m\n",
    "    return [v, ax]\n",
    "\n",
    "m = 1.0; k_spring = 4.0   # omega_n = sqrt(k/m) = 2 rad/s\n",
    "omega_n = np.sqrt(k_spring/m)\n",
    "t = np.linspace(0, 30, 3000)\n",
    "\n",
    "scenarios = [\n",
    "    {'c': 0.0,  'F0': 0, 'omega_drive': 0,         'label': 'Undamped SHM',           'y0': [1, 0]},\n",
    "    {'c': 0.5,  'F0': 0, 'omega_drive': 0,         'label': 'Underdamped (c=0.5)',     'y0': [1, 0]},\n",
    "    {'c': 4.0,  'F0': 0, 'omega_drive': 0,         'label': 'Overdamped  (c=4.0)',     'y0': [1, 0]},\n",
    "    {'c': 0.3,  'F0': 1, 'omega_drive': omega_n,   'label': 'Resonance (ω = ωₙ)',      'y0': [0, 0]},\n",
    "]\n",
    "\n",
    "fig, axes = plt.subplots(2, 2, figsize=(14, 9))\n",
    "fig.suptitle('Harmonic Oscillator — Damping & Resonance', fontsize=14, fontweight='bold', color='#a6e3a1')\n",
    "axes = axes.flatten()\n",
    "\n",
    "for ax, sc in zip(axes, scenarios):\n",
    "    sol = solve_ivp(oscillator, [0, 30], sc['y0'],\n",
    "                    args=(m, sc['c'], k_spring, sc['F0'], sc['omega_drive']),\n",
    "                    t_eval=t, method='RK45', rtol=1e-10)\n",
    "    ax.plot(sol.t, sol.y[0], color=COLORS[0], lw=1.8)\n",
    "    ax.fill_between(sol.t, sol.y[0], alpha=0.15, color=COLORS[0])\n",
    "    ax.set(xlabel='Time (s)', ylabel='x(t)  [m]', title=sc['label'])\n",
    "    ax.axhline(0, color='#444', lw=0.8)\n",
    "    ax.grid(True)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('oscillator.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 3 · Wave Interference & Standing Waves\n",
    "\n",
    "$$y_1 = A\\sin(kx - \\omega t) \\qquad y_2 = A\\sin(kx + \\omega t) \\qquad y_{standing} = 2A\\sin(kx)\\cos(\\omega t)$$"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "x  = np.linspace(0, 4*np.pi, 500)\n",
    "A  = 1.0\n",
    "k  = 1.0    # wave number\n",
    "omega = 2.0  # angular frequency\n",
    "snapshots = [0, np.pi/4, np.pi/2, 3*np.pi/4]\n",
    "\n",
    "fig, axes = plt.subplots(3, 4, figsize=(16, 9))\n",
    "fig.suptitle('Wave Interference & Standing Waves', fontsize=14, fontweight='bold', color='#fab387')\n",
    "\n",
    "row_titles = ['Wave 1 →', 'Wave 2 ←', 'Superposition (Standing)']\n",
    "for row, rt in enumerate(row_titles):\n",
    "    axes[row, 0].set_ylabel(rt, fontsize=10, labelpad=6)\n",
    "\n",
    "for col, t_snap in enumerate(snapshots):\n",
    "    y1   = A * np.sin(k*x - omega*t_snap)\n",
    "    y2   = A * np.sin(k*x + omega*t_snap)\n",
    "    y_sum = y1 + y2\n",
    "\n",
    "    axes[0, col].plot(x, y1,    color=COLORS[0], lw=2)\n",
    "    axes[1, col].plot(x, y2,    color=COLORS[2], lw=2)\n",
    "    axes[2, col].plot(x, y_sum, color=COLORS[4], lw=2)\n",
    "    axes[2, col].fill_between(x, y_sum, alpha=0.2, color=COLORS[4])\n",
    "\n",
    "    for row in range(3):\n",
    "        axes[row, col].set_ylim(-2.2, 2.2)\n",
    "        axes[row, col].axhline(0, color='#444', lw=0.8)\n",
    "        axes[row, col].set_title(f't = {t_snap/np.pi:.2f}π s', fontsize=9)\n",
    "        if row == 2: axes[row, col].set_xlabel('x')\n",
    "        axes[row, col].grid(True)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('waves.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 4 · Two-Body Gravitational Orbit\n",
    "\n",
    "$$\\ddot{\\mathbf{r}} = -\\frac{GM}{|\\mathbf{r}|^3}\\mathbf{r}$$\n",
    "\n",
    "Simulated using RK45 — compare circular, elliptical, and hyperbolic orbits."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "GM = 4 * np.pi**2   # AU³/yr² (G×M_sun in astronomical units)\n",
    "\n",
    "def gravity(t, y):\n",
    "    x, vx, yp, vy = y\n",
    "    r3 = (x**2 + yp**2)**1.5\n",
    "    return [vx, -GM*x/r3, vy, -GM*yp/r3]\n",
    "\n",
    "# (x0, vy0, label, color_idx) — different initial velocities give different orbits\n",
    "orbits = [\n",
    "    (1.0, 2*np.pi,         'Circular  (vy = vₒ)',         0),\n",
    "    (1.0, 2*np.pi*0.75,    'Elliptical (vy < vₒ)',        1),\n",
    "    (1.0, 2*np.pi*1.25,    'Elliptical (vy > vₒ)',        2),\n",
    "    (1.0, 2*np.pi*1.415,   'Near-escape  (vy ≈ v_esc)',   3),\n",
    "]\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(8, 8))\n",
    "fig.suptitle('Gravitational Orbits (RK45)', fontsize=14, fontweight='bold', color='#cba6f7')\n",
    "\n",
    "ax.scatter([0], [0], color='#fab387', s=200, zorder=5, label='Star')\n",
    "\n",
    "for x0, vy0, lbl, ci in orbits:\n",
    "    sol = solve_ivp(gravity, [0, 5], [x0, 0, 0, vy0],\n",
    "                    method='RK45', rtol=1e-10, max_step=0.002,\n",
    "                    t_eval=np.linspace(0, 5, 5000))\n",
    "    ax.plot(sol.y[0], sol.y[2], color=COLORS[ci], lw=1.8, label=lbl)\n",
    "    ax.scatter(sol.y[0][0], sol.y[2][0], color=COLORS[ci], s=50, zorder=4)\n",
    "\n",
    "ax.set(xlabel='x (AU)', ylabel='y (AU)', title='Orbital Paths around Central Star')\n",
    "ax.set_aspect('equal')\n",
    "ax.legend(fontsize=9); ax.grid(True)\n",
    "plt.tight_layout()\n",
    "plt.savefig('orbits.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 5 · 1D Heat Diffusion — Finite Difference Method\n",
    "\n",
    "$$\\frac{\\partial T}{\\partial t} = \\alpha \\frac{\\partial^2 T}{\\partial x^2}$$\n",
    "\n",
    "Solved using explicit FTCS (Forward Time, Centred Space) finite differences."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Parameters\n",
    "L      = 1.0      # rod length [m]\n",
    "alpha  = 1e-4     # thermal diffusivity [m²/s]\n",
    "T_left, T_right = 100.0, 0.0\n",
    "T_init = 20.0     # initial temperature [°C]\n",
    "\n",
    "Nx  = 100\n",
    "dx  = L / (Nx - 1)\n",
    "dt  = 0.4 * dx**2 / alpha   # stability: r = alpha*dt/dx² < 0.5\n",
    "r   = alpha * dt / dx**2\n",
    "print(f'Grid: Nx={Nx}, dx={dx:.4f} m, dt={dt:.2f} s, r={r:.3f}  (must be < 0.5)')\n",
    "\n",
    "x = np.linspace(0, L, Nx)\n",
    "T = np.full(Nx, T_init)\n",
    "T[0]  = T_left\n",
    "T[-1] = T_right\n",
    "\n",
    "# Steady-state (analytical)\n",
    "T_ss = T_left + (T_right - T_left) * x / L\n",
    "\n",
    "# Time-march and store snapshots\n",
    "t_snapshots = [0, 30, 120, 600, 3000]\n",
    "T_snaps     = {0: T.copy()}\n",
    "t_curr      = 0.0\n",
    "\n",
    "while t_curr < max(t_snapshots):\n",
    "    T_new = T.copy()\n",
    "    T_new[1:-1] = T[1:-1] + r * (T[2:] - 2*T[1:-1] + T[:-2])\n",
    "    T_new[0]  = T_left\n",
    "    T_new[-1] = T_right\n",
    "    T = T_new\n",
    "    t_curr += dt\n",
    "    for ts in t_snapshots[1:]:\n",
    "        if abs(t_curr - ts) < dt/2 and ts not in T_snaps:\n",
    "            T_snaps[ts] = T.copy()\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 6))\n",
    "for i, ts in enumerate(t_snapshots):\n",
    "    if ts in T_snaps:\n",
    "        ax.plot(x, T_snaps[ts], color=COLORS[i], lw=2, label=f't = {ts} s')\n",
    "ax.plot(x, T_ss, color='white', lw=1.5, linestyle='--', label='Steady-state')\n",
    "ax.set(xlabel='Position x (m)', ylabel='Temperature T (°C)',\n",
    "       title='Heat Diffusion in a Rod — FTCS Finite Difference')\n",
    "ax.legend(); ax.grid(True)\n",
    "plt.tight_layout()\n",
    "plt.savefig('heat_diffusion.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## ✅ Summary\n",
    "\n",
    "| Section | Physics | Numerical Method |\n",
    "|---------|---------|------------------|\n",
    "| Projectile Motion | Newton's 2nd law + drag | `solve_ivp` RK45 |\n",
    "| Harmonic Oscillator | SHM + damping + forcing | `solve_ivp` RK45 |\n",
    "| Wave Interference | Superposition principle | Analytical (vectorised) |\n",
    "| Gravitational Orbits | Inverse-square gravity | `solve_ivp` RK45 |\n",
    "| Heat Diffusion | Fourier's law / PDE | FTCS Finite Differences |\n",
    "\n",
    "> **Tip:** Modify the initial conditions in each cell to explore different physical regimes — try making the orbit escape to infinity, or create a standing wave with a different wavelength!"
   ]
  }
